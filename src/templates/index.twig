{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = "Tidy Tags"|t('tidytags') %}
{% set selectedSubnavItem = "dashboard" %}

{% block content %}
<div class="tidytags-dashboard">
    {% if rows|length == 0 %}
        <p>
            No sources found. Create a tag group in <a href="{{ cpUrl('settings/tags') }}">Settings → Tags</a>,
            or designate a channel section as tag-like in
            <a href="{{ cpUrl('settings/plugins/tidytags') }}">Settings → Tidy Tags</a>
            (useful if you've run <code>php craft entrify/tags</code>).
        </p>
    {% else %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>Source</th>
                    <th>Total</th>
                    {% for site in sites %}
                        <th>{{ site.name }}</th>
                    {% endfor %}
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for row in rows %}
                    {% set source = row.source %}
                    <tr>
                        <td>
                            <strong>{{ source.name }}</strong>
                            <span class="tidytags-type-badge tidytags-type-{{ source.type }}"
                                  style="display:inline-block;margin-left:6px;padding:1px 6px;border-radius:10px;font-size:10px;text-transform:uppercase;letter-spacing:.04em;background:{{ source.type == 'tag' ? '#e3efff' : '#fff1e3' }};color:{{ source.type == 'tag' ? '#0b5394' : '#8a4b00' }};">
                                {{ source.typeLabel }}
                            </span>
                            {% if not source.isWritable %}
                                <span title="Read-only: rename, merge, and delete are disabled for entry-backed sources."
                                      style="margin-left:4px;font-size:11px;color:#8a8a8a;">read-only</span>
                            {% endif %}
                            <br>
                            <code style="font-size:11px;color:#596673;">{{ source.handle }}</code>
                        </td>
                        <td>{{ row.total }}</td>
                        {% for site in sites %}
                            <td>
                                <span class="site-count">{{ row.countsBySite[site.id] ?? 0 }}</span>
                            </td>
                        {% endfor %}
                        <td>
                            <a class="btn small" href="{{ cpUrl(source.cpPath) }}">Manage</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
{% endblock %}
